# Copy to .env and fill in your keys. Never commit .env.

# REQUIRED — free at https://aistudio.google.com/apikey
# Free tier = 10 requests per MINUTE per key and 500 per day.
# In class, set `temperature=0` in notebooks and avoid retries. If you hit a
# 429, wait 10 seconds or ask the instructor for the fallback key.
GOOGLE_API_KEY=

# OPTIONAL — only needed for Ex 5. Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OPTIONAL — for the GLM-5.1 swap demo. Sign up at https://openrouter.ai
OPENROUTER_API_KEY=

# OPTIONAL — Ex 4 observability. Free at https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=w10-hands-on
